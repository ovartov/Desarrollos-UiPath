                    <ui:InvokeCode ContinueOnError="{x:Null}" Code="' Agregar columna nombreBanco al principio si no existe&#xA;If Not dtCuentas.Columns.Contains(&quot;nombreBanco&quot;) Then&#xA;    dtCuentas.Columns.Add(&quot;nombreBanco&quot;, GetType(String))&#xA;    dtCuentas.Columns(&quot;nombreBanco&quot;).SetOrdinal(0)&#xA;End If&#xA;&#xA;Dim rowsToDelete As New System.Collections.Generic.List(Of System.Data.DataRow)()&#xA;For Each row As System.Data.DataRow In dtCuentas.Rows&#xA;    Dim numeroCuenta As String = row(&quot;numeroCuenta&quot;).ToString().Trim()&#xA;    Dim tipoCuenta As String = row(&quot;tipoCuenta&quot;).ToString().Trim()&#xA;    Dim saldo As String = row(&quot;saldo&quot;).ToString().Trim()&#xA;    &#xA;    ' Marcar fila para eliminar si todos los campos estan vacios&#xA;    If String.IsNullOrEmpty(numeroCuenta) AndAlso String.IsNullOrEmpty(tipoCuenta) AndAlso String.IsNullOrEmpty(saldo) Then&#xA;        rowsToDelete.Add(row)&#xA;        Continue For&#xA;    End If&#xA;&#xA;    ' Asignar nombreBanco&#xA;    row(&quot;nombreBanco&quot;) = strNameBank&#xA;    &#xA;    ' Normalizar saldo si no esta vacio&#xA;    If Not String.IsNullOrEmpty(saldo) AndAlso saldo.Length &gt;= 4 Then&#xA;        Dim resultado As String = &quot;&quot;&#xA;        &#xA;        ' Limpiar el simbolo $ y espacios&#xA;        Dim saldoLimpio As String = saldo.Replace(&quot;$&quot;, &quot;&quot;).Trim()&#xA;        &#xA;        ' Obtener caracteres clave para identificar formato&#xA;        Dim penultimoIndex As Integer = saldoLimpio.Length - 2&#xA;        Dim charAntesPenultimo As Char = saldoLimpio(penultimoIndex - 1)&#xA;        Dim ultimoChar As Char = saldoLimpio(saldoLimpio.Length - 1)&#xA;        Dim penultimoChar As Char = saldoLimpio(saldoLimpio.Length - 2)&#xA;        &#xA;        ' Verificar si tiene decimales&#xA;        Dim ultimosSonDigitos As Boolean = Char.IsDigit(ultimoChar) AndAlso Char.IsDigit(penultimoChar)&#xA;        Dim tieneDecimales As Boolean = 