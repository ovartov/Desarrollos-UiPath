      <ui:InvokeCode ContinueOnError="{x:Null}" Code="' Inicializar tabla de registros sin match&#xA;dtCuentasNoMatch = dtDataExtract.Clone()&#xA;&#xA;' Bancos que requieren validación por últimos 4 dígitos (búsqueda exacta por entidad)&#xA;Dim bancosUltimos4 As String() = {&quot;BANCO AGRARIO&quot;, &quot;BANCO DE OCCIDENTE&quot;, &quot;BANCO POPULAR&quot;}&#xA;&#xA;' Bancos que requieren validación por últimos 4 dígitos buscando en múltiples entidades&#xA;Dim bancosUltimos4Multi As String() = {&quot;BANCO CAJA SOCIAL&quot;, &quot;BANCO BCSC S.A.&quot;}&#xA;&#xA;' Mapeo Banco de Bogota: Numero Cuenta -&gt; COD en dtBoletinTemp&#xA;Dim mapaBogota As New Dictionary(Of String, String)()&#xA;mapaBogota.Add(&quot;IND Y CCIO&quot;, &quot;0057&quot;)&#xA;mapaBogota.Add(&quot;PREDIAL&quot;, &quot;0056&quot;)&#xA;mapaBogota.Add(&quot;SGP SAL REG SUBS&quot;, &quot;0135&quot;)&#xA;&#xA;' Mapeo Banco AV Villas: Numero Cuenta -&gt; COD en dtBoletinTemp&#xA;Dim mapaAvVillas As New Dictionary(Of String, String)()&#xA;mapaAvVillas.Add(&quot;RECAUDOS VARIOS&quot;, &quot;0034&quot;)&#xA;mapaAvVillas.Add(&quot;PREDIAL&quot;, &quot;0053&quot;)&#xA;mapaAvVillas.Add(&quot;IND Y CCIO&quot;, &quot;0052&quot;)&#xA;&#xA;' ---- Función helper para normalizar cuentas BBVA ----&#xA;Dim normalizarBBVA As Func(Of String, String) = Function(cuenta As String) As String&#xA;    ' Paso 1: Reemplazar guiones por vacío&#xA;    Dim result As String = cuenta.Replace(&quot;-&quot;, &quot;&quot;).Trim()&#xA;&#xA;    ' Paso 2: Reemplazar 0130 solo en los primeros 6 dígitos&#xA;    If result.Length &gt;= 6 Then&#xA;        Dim primeros6 As String = result.Substring(0, 6)&#xA;        Dim resto As String = result.Substring(6)&#xA;        primeros6 = primeros6.Replace(&quot;0130&quot;, &quot;&quot;)&#xA;        result = primeros6 &amp; resto&#xA;    End If&#xA;&#xA;    ' Paso 3: Borrar ceros a la izquierda&#xA;    result = result.TrimStart(&quot;0&quot;c)&#xA;    If String.IsNullOrEmpty(result) Then result = &quot;0&quot;&#xA;&#xA;    ' Paso 4: Reemplazar 0001000 por vacío&#xA;    result = result.Replace(&quot;0001000&quot;, &quot;&quot;)&#xA;&#xA;    ' Paso 5: Reemplazar 0002000 por vacío&#xA;    result = result.Replace(&quot;0002000&quot;, &quot;&quot;)&#xA;&#xA;    ' Paso 6: Borrar ceros a la izquierda de nuevo&#xA;    result = result.TrimStart(&quot;0&quot;c)&#xA;    If String.IsNullOrEmpty(result) Then result = &quot;0&quot;&#xA;&#xA;    ' Paso 7: Tomar primeros 3 y últimos 4 dígitos&#xA;    Dim primeros3 As String = &quot;&quot;&#xA;    Dim ultimos4 As String = &quot;&quot;&#xA;&#xA;    If result.Length &gt;= 3 Then&#xA;        primeros3 = result.Substring(0, 3)&#xA;    Else&#xA;        primeros3 = result.PadLeft(3, &quot;0&quot;c)&#xA;    End If&#xA;&#xA;    If result.Length &gt;= 4 Then&#xA;        ultimos4 = result.Substring(result.Length - 4)&#xA;    Else&#xA;        ultimos4 = result.PadLeft(4, &quot;0&quot;c)&#xA;    End If&#xA;&#xA;    Return primeros3 &amp; ultimos4&#xA;End Function&#xA;&#xA;For Each rowExtract As System.Data.DataRow In dtDataExtract.Rows&#xA;    Dim entidadBancaria As String = System.Text.RegularExpressions.Regex.Replace(rowExtract(&quot;Entidad Bancaria&quot;).ToString().Trim().ToUpper(), &quot;\s+&quot;, &quot; &quot;)&#xA;    Dim numeroCuentaExtract As String = rowExtract(&quot;Numero Cuenta&quot;).ToString().Replace(&quot; &quot;, &quot;&quot;).Replace(&quot;-&quot;, &quot;&quot;).Trim()&#xA;    Dim numeroCuentaExtractOriginal As String = rowExtract(&quot;Numero Cuenta&quot;).ToString().Trim().ToUpper()&#xA;    Dim saldoExtract As String = rowExtract(&quot;Saldo&quot;).ToString().Trim()&#xA;&#xA;    ' Detectar bancos especiales por Contains&#xA;    Dim esDavivienda As Boolean = entidadBancaria.Contains(&quot;BANCO DAVIVIENDA&quot;)&#xA;    Dim esBogota As Boolean = entidadBancaria.Contains(&quot;BANCO DE BOGOTA&quot;)&#xA;    Dim esAvVillas As Boolean = entidadBancaria.Contains(&quot;BANCO AV VILLAS&quot;)&#xA;    Dim esCajaSocial As Boolean = bancosUltimos4Multi.Contains(entidadBancaria)&#xA;    Dim esBBVA As Boolean = entidadBancaria.Contains(&quot;BBVA COLOMBIA&quot;)&#xA;    Dim esBancolombia As Boolean = entidadBancaria.Contains(&quot;BANCOLOMBIA&quot;)&#xA;    Dim esIDEA As Boolean = entidadBancaria.Contains(&quot;INSTITUTO PARA EL DESARROLLO DE ANTIOQUI&quot;)&#xA;    Dim esScotiabank As Boolean = entidadBancaria.Contains(&quot;SCOTIABANK COLPATRIA&quot;)&#xA;    Dim esNoMatch As Boolean = entidadBancaria.Contains(&quot;FINANCIERA JURISCOOP&quot;) OrElse&#xA;                               entidadBancaria.Contains(&quot;FONDO DE INVERSION COLECTIVA ABIERTA FIDUPREVISORA&quot;)&#xA;&#xA;    ' ---- Enviar directamente a dtCuentasNoMatch: Scotiabank, Juriscoop, Fiduprevisora ----&#xA;    If esScotiabank OrElse esNoMatch Then&#xA;        Dim newRowNoMatch As System.Data.DataRow = dtCuentasNoMatch.NewRow()&#xA;        For Each col As System.Data.DataColumn In dtDataExtract.Columns&#xA;            newRowNoMatch(col.ColumnName) = rowExtract(col.ColumnName)&#xA;        Next&#xA;        dtCuentasNoMatch.Rows.Add(newRowNoMatch)&#xA;        Continue For&#xA;    End If&#xA;&#xA;    ' Solo procesar bancos de las listas definidas&#xA;    If Not bancosUltimos4.Contains(entidadBancaria) AndAlso&#xA;       Not esBancolombia AndAlso&#xA;       Not esIDEA AndAlso&#xA;       Not esDavivienda AndAlso&#xA;       Not esBogota AndAlso&#xA;       Not esAvVillas AndAlso&#xA;       Not esCajaSocial AndAlso&#xA;       Not esBBVA Then&#xA;        Continue For&#xA;    End If&#xA;&#xA;    Dim matchFound As Boolean = False&#xA;&#xA;    If esBogota OrElse esAvVillas Then&#xA;        ' ---- Validación Banco de Bogotá / AV Villas por mapeo Numero Cuenta -&gt; COD ----&#xA;        Dim numeroCuentaNorm As String = System.Text.RegularExpressions.Regex.Replace(numeroCuentaExtractOriginal, &quot;\s+&quot;, &quot; &quot;).Trim()&#xA;        Dim mapaActual As Dictionary(Of String, String) = If(esBogota, mapaBogota, mapaAvVillas)&#xA;&#xA;        If mapaActual.ContainsKey(numeroCuentaNorm) Then&#xA;            Dim codBuscado As String = mapaActual(numeroCuentaNorm)&#xA;&#xA;            Dim filasMatch = dtBoletinTemp.AsEnumerable() _&#xA;                .Where(Function(r) r(&quot;COD&quot;).ToString().Trim() = codBuscado) _&#xA;                .ToList()&#xA;&#xA;            For Each rowBoletin As System.Data.DataRow In filasMatch&#xA;                rowBoletin(&quot;SALDO BANCO&quot;) = saldoExtract&#xA;                matchFound = True&#xA;            Next&#xA;        End If&#xA;&#xA;    ElseIf esCajaSocial Then&#xA;        ' ---- Validación Banco Caja Social / BCSC: últimos 4 dígitos buscando en ambas entidades ----&#xA;        Dim ultimos4Extract As String = &quot;&quot;&#xA;        If numeroCuentaExtract.Length &gt;= 4 Then&#xA;            ultimos4Extract = numeroCuentaExtract.Substring(numeroCuentaExtract.Length - 4)&#xA;        End If&#xA;&#xA;        Dim filasCajaSocial = dtBoletinTemp.AsEnumerable() _&#xA;            .Where(Function(r)&#xA;                       Dim bancoBoletin As String = System.Text.RegularExpressions.Regex.Replace(r(&quot;BANCOS&quot;).ToString().Trim().ToUpper(), &quot;\s+&quot;, &quot; &quot;)&#xA;                       Return bancosUltimos4Multi.Contains(bancoBoletin)&#xA;                   End Function) _&#xA;            .ToList()&#xA;&#xA;        For Each rowBoletin As System.Data.DataRow In filasCajaSocial&#xA;            Dim noCuentaBoletin As String = rowBoletin(&quot;No. CUENTA&quot;).ToString().Replace(&quot; &quot;, &quot;&quot;).Replace(&quot;-&quot;, &quot;&quot;).Trim()&#xA;            Dim ultimos4Boletin As String = &quot;&quot;&#xA;            If noCuentaBoletin.Length &gt;= 4 Then&#xA;                ultimos4Boletin = noCuentaBoletin.Substring(noCuentaBoletin.Length - 4)&#xA;            End If&#xA;&#xA;            If ultimos4Boletin = ultimos4Extract Then&#xA;                rowBoletin(&quot;SALDO BANCO&quot;) = saldoExtract&#xA;                matchFound = True&#xA;            End If&#xA;        Next&#xA;&#xA;    ElseIf esBBVA Then&#xA;        ' ---- Validación BBVA COLOMBIA: normalización por pasos (3 primeros + 4 últimos) ----&#xA;        Dim normExtract As String = normalizarBBVA(numeroCuentaExtractOriginal)&#xA;&#xA;        Dim filasBBVA = dtBoletinTemp.AsEnumerable() _&#xA;            .Where(Function(r)&#xA;                       Dim bancoBoletin As String = System.Text.RegularExpressions.Regex.Replace(r(&quot;BANCOS&quot;).ToString().Trim().ToUpper(), &quot;\s+&quot;, &quot; &quot;)&#xA;                       Return bancoBoletin.Contains(&quot;BBVA COLOMBIA&quot;)&#xA;                   End Function) _&#xA;            .ToList()&#xA;&#xA;        For Each rowBoletin As System.Data.DataRow In filasBBVA&#xA;            Dim normBoletin As String = normalizarBBVA(rowBoletin(&quot;No. CUENTA&quot;).ToString())&#xA;&#xA;            If normExtract = normBoletin Then&#xA;                rowBoletin(&quot;SALDO BANCO&quot;) = saldoExtract&#xA;                matchFound = True&#xA;            End If&#xA;        Next&#xA;&#xA;    ElseIf esBancolombia OrElse esIDEA Then&#xA;        ' ---- Validación BANCOLOMBIA / IDEA: Numero Cuenta contenido en No. CUENTA (bidireccional) ----&#xA;        Dim filasBancoContenido = dtBoletinTemp.AsEnumerable() _&#xA;            .Where(Function(r)&#xA;                       Dim bancoBoletin As String = System.Text.RegularExpressions.Regex.Replace(r(&quot;BANCOS&quot;).ToString().Trim().ToUpper(), &quot;\s+&quot;, &quot; &quot;)&#xA;                       If esBancolombia Then Return bancoBoletin.Contains(&quot;BANCOLOMBIA&quot;)&#xA;                       Return bancoBoletin.Contains(&quot;INSTITUTO PARA EL DESARROLLO DE ANTIOQUI&quot;)&#xA;                   End Function) _&#xA;            .ToList()&#xA;&#xA;        For Each rowBoletin As System.Data.DataRow In filasBancoContenido&#xA;            Dim noCuentaBoletin As String = rowBoletin(&quot;No. CUENTA&quot;).ToString().Replace(&quot; &quot;, &quot;&quot;).Replace(&quot;-&quot;, &quot;&quot;).Trim()&#xA;&#xA;            If noCuentaBoletin.Contains(numeroCuentaExtract) OrElse numeroCuentaExtract.Contains(noCuentaBoletin) Then&#xA;                rowBoletin(&quot;SALDO BANCO&quot;) = saldoExtract&#xA;                matchFound = True&#xA;            End If&#xA;        Next&#xA;&#xA;    ElseIf bancosUltimos4.Contains(entidadBancaria) Then&#xA;        ' ---- Validación por últimos 4 dígitos ----&#xA;        Dim ultimos4Extract As String = &quot;&quot;&#xA;        If numeroCuentaExtract.Length &gt;= 4 Then&#xA;            ultimos4Extract = numeroCuentaExtract.Substring(numeroCuentaExtract.Length - 4)&#xA;        End If&#xA;&#xA;        Dim filasBoletin = dtBoletinTemp.AsEnumerable() _&#xA;            .Where(Function(r)&#xA;                       Dim bancoBoletin As String = System.Text.RegularExpressions.Regex.Replace(r(&quot;BANCOS&quot;).ToString().Trim().ToUpper(), &quot;\s+&quot;, &quot; &quot;)&#xA;                       Return bancoBoletin = entidadBancaria&#xA;                   End Function) _&#xA;            .ToList()&#xA;&#xA;        For Each rowBoletin As System.Data.DataRow In filasBoletin&#xA;            Dim noCuentaBoletin As String = rowBoletin(&quot;No. CUENTA&quot;).ToString().Replace(&quot; &quot;, &quot;&quot;).Replace(&quot;-&quot;, &quot;&quot;).Trim()&#xA;            Dim ultimos4Boletin As String = &quot;&quot;&#xA;            If noCuentaBoletin.Length &gt;= 4 Then&#xA;                ultimos4Boletin = noCuentaBoletin.Substring(noCuentaBoletin.Length - 4)&#xA;            End If&#xA;&#xA;            If ultimos4Boletin = ultimos4Extract Then&#xA;                rowBoletin(&quot;SALDO BANCO&quot;) = saldoExtract&#xA;                matchFound = True&#xA;            End If&#xA;        Next&#xA;&#xA;    ElseIf esDavivienda Then&#xA;        ' ---- Validación DAVIVIENDA: No. CUENTA (Boletin) contenido en Numero Cuenta (Extract) ----&#xA;        Dim filasDavivienda = dtBoletinTemp.AsEnumerable() _&#xA;            .Where(Function(r)&#xA;                       Dim bancoBoletin As String = System.Text.RegularExpressions.Regex.Replace(r(&quot;BANCOS&quot;).ToString().Trim().ToUpper(), &quot;\s+&quot;, &quot; &quot;)&#xA;                       Return bancoBoletin.Contains(&quot;BANCO DAVIVIENDA&quot;)&#xA;                   End Function) _&#xA;            .ToList()&#xA;&#xA;        For Each rowBoletin As System.Data.DataRow In filasDavivienda&#xA;            Dim noCuentaBoletin As String = rowBoletin(&quot;No. CUENTA&quot;).ToString().Replace(&quot; &quot;, &quot;&quot;).Replace(&quot;-&quot;, &quot;&quot;).Trim()&#xA;&#xA;            If numeroCuentaExtract.Contains(noCuentaBoletin) OrElse noCuentaBoletin.Contains(numeroCuentaExtract) Then&#xA;                rowBoletin(&quot;SALDO BANCO&quot;) = saldoExtract&#xA;                matchFound = True&#xA;            End If&#xA;        Next&#xA;&#xA;    End If&#xA;&#xA;    ' Si no hubo match agregar a dtCuentasNoMatch&#xA;    If Not matchFound Then&#xA;        Dim newRow As System.Data.DataRow = dtCuentasNoMatch.NewRow()&#xA;        For Each col As System.Data.DataColumn In dtDataExtract.Columns&#xA;            newRow(col.ColumnName) = rowExtract(col.ColumnName)&#xA;        Next&#xA;        dtCuentasNoMatch.Rows.Add(newRow)&#xA;    End If&#xA;Next&#xA;&#xA;dtBoletinTemp.AcceptChanges()&#xA;dtCuentasNoMatch.AcceptChanges()" DisplayName="Invoke Code - Actualizar Saldos Banco" sap:VirtualizedContainerService.HintSize="546,57" sap2010:WorkflowViewState.IdRef="InvokeCode_5">
