      <ui:InvokeCode ContinueOnError="{x:Null}" Code="' Limpiar y normalizar columna FTE antes de procesar&#xD;&#xA;Dim dtBoletinNorm As System.Data.DataTable = dtBoletinTemp.Copy()&#xD;&#xA;For Each rowNorm As System.Data.DataRow In dtBoletinNorm.Rows&#xD;&#xA;    rowNorm(&quot;FTE&quot;) = If(IsDBNull(rowNorm(&quot;FTE&quot;)), &quot;SIN FTE&quot;, rowNorm(&quot;FTE&quot;).ToString().Trim().ToUpper())&#xD;&#xA;    rowNorm(&quot;SALDO BOLETIN&quot;) = If(IsDBNull(rowNorm(&quot;SALDO BOLETIN&quot;)), &quot;0&quot;, rowNorm(&quot;SALDO BOLETIN&quot;).ToString().Trim())&#xD;&#xA;    rowNorm(&quot;SALDO BANCO&quot;) = If(IsDBNull(rowNorm(&quot;SALDO BANCO&quot;)), &quot;0&quot;, rowNorm(&quot;SALDO BANCO&quot;).ToString().Trim())&#xD;&#xA;    rowNorm(&quot;DIFERENCIA&quot;) = If(IsDBNull(rowNorm(&quot;DIFERENCIA&quot;)), &quot;0&quot;, rowNorm(&quot;DIFERENCIA&quot;).ToString().Trim())&#xD;&#xA;Next&#xD;&#xA;&#xD;&#xA;' Obtener grupos únicos de FTE manteniendo el orden original&#xD;&#xA;Dim grupos As String() = dtBoletinNorm.AsEnumerable() _&#xD;&#xA;    .Select(Function(r) r(&quot;FTE&quot;).ToString().Trim().ToUpper()) _&#xD;&#xA;    .Where(Function(v) Not String.IsNullOrEmpty(v)) _&#xD;&#xA;    .Distinct() _&#xD;&#xA;    .ToArray()&#xD;&#xA;&#xD;&#xA;' Crear tabla destino con las mismas columnas&#xD;&#xA;dtBoletinFinanciero = New System.Data.DataTable()&#xD;&#xA;For Each col As System.Data.DataColumn In dtBoletinNorm.Columns&#xD;&#xA;    dtBoletinFinanciero.Columns.Add(col.ColumnName, GetType(String))&#xD;&#xA;Next&#xD;&#xA;&#xD;&#xA;' Variables para acumulado total&#xD;&#xA;Dim grandTotalSaldoBoletin As Decimal = 0&#xD;&#xA;Dim grandTotalSaldoBanco As Decimal = 0&#xD;&#xA;Dim grandTotalDiferencia As Decimal = 0&#xD;&#xA;&#xD;&#xA;' CORRECCIÓN: separador decimal = &quot;.&quot; | separador de miles = &quot;,&quot; (se elimina)&#xD;&#xA;' Funciona para números de cualquier tamaño ej: 1000060690983247.89&#xD;&#xA;Dim parsearDecimal As Func(Of String, Decimal) = Function(val As String) As Decimal&#xD;&#xA;    Dim clean As String = val.ToString().Trim().Replace(&quot;$&quot;, &quot;&quot;).Replace(&quot; &quot;, &quot;&quot;)&#xD;&#xA;    clean = clean.Replace(&quot;,&quot;, &quot;&quot;)  ' Eliminar separador de miles sin importar tamaño&#xD;&#xA;    Dim result As Decimal = 0&#xD;&#xA;    Decimal.TryParse(clean, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, result)&#xD;&#xA;    Return result&#xD;&#xA;End Function&#xD;&#xA;&#xD;&#xA;' Iterar cada grupo&#xD;&#xA;For Each grupo As String In grupos&#xD;&#xA;    ' Filtrar filas del grupo&#xD;&#xA;    Dim filas = dtBoletinNorm.AsEnumerable() _&#xD;&#xA;        .Where(Function(r) r(&quot;FTE&quot;).ToString().Trim().ToUpper() = grupo) _&#xD;&#xA;        .ToList()&#xD;&#xA;&#xD;&#xA;    ' Agregar filas del grupo&#xD;&#xA;    For Each fila As System.Data.DataRow In filas&#xD;&#xA;        Dim newRow As System.Data.DataRow = dtBoletinFinanciero.NewRow()&#xD;&#xA;        For Each col As System.Data.DataColumn In dtBoletinNorm.Columns&#xD;&#xA;            newRow(col.ColumnName) = fila(col.ColumnName).ToString()&#xD;&#xA;        Next&#xD;&#xA;        dtBoletinFinanciero.Rows.Add(newRow)&#xD;&#xA;    Next&#xD;&#xA;&#xD;&#xA;    ' Calcular subtotales del grupo&#xD;&#xA;    Dim totalSaldoBoletin As Decimal = filas.Sum(Function(f) parsearDecimal(f(&quot;SALDO BOLETIN&quot;).ToString()))&#xD;&#xA;    Dim totalSaldoBanco As Decimal = filas.Sum(Function(f) parsearDecimal(f(&quot;SALDO BANCO&quot;).ToString()))&#xD;&#xA;    Dim totalDiferencia As Decimal = filas.Sum(Function(f) parsearDecimal(f(&quot;DIFERENCIA&quot;).ToString()))&#xD;&#xA;&#xD;&#xA;    ' Acumular en totales generales&#xD;&#xA;    grandTotalSaldoBoletin += totalSaldoBoletin&#xD;&#xA;    grandTotalSaldoBanco += totalSaldoBanco&#xD;&#xA;    grandTotalDiferencia += totalDiferencia&#xD;&#xA;&#xD;&#xA;    ' CORRECCIÓN: &quot;F2&quot; + InvariantCulture evita comas de miles en cualquier número&#xD;&#xA;    Dim subtotalRow As System.Data.DataRow = dtBoletinFinanciero.NewRow()&#xD;&#xA;    subtotalRow(&quot;FTE&quot;) = &quot;SUBTOTAL &quot; &amp; grupo&#xD;&#xA;    subtotalRow(&quot;SALDO BOLETIN&quot;) = totalSaldoBoletin.ToString(&quot;F2&quot;, System.Globalization.CultureInfo.InvariantCulture)&#xD;&#xA;    subtotalRow(&quot;SALDO BANCO&quot;) = totalSaldoBanco.ToString(&quot;F2&quot;, System.Globalization.CultureInfo.InvariantCulture)&#xD;&#xA;    subtotalRow(&quot;DIFERENCIA&quot;) = totalDiferencia.ToString(&quot;F2&quot;, System.Globalization.CultureInfo.InvariantCulture)&#xD;&#xA;    dtBoletinFinanciero.Rows.Add(subtotalRow)&#xD;&#xA;Next&#xD;&#xA;&#xD;&#xA;' CORRECCIÓN: &quot;F2&quot; + InvariantCulture en fila de total general&#xD;&#xA;Dim grandTotalRow As System.Data.DataRow = dtBoletinFinanciero.NewRow()&#xD;&#xA;grandTotalRow(&quot;FTE&quot;) = &quot;TOTAL GENERAL&quot;&#xD;&#xA;grandTotalRow(&quot;SALDO BOLETIN&quot;) = grandTotalSaldoBoletin.ToString(&quot;F2&quot;, System.Globalization.CultureInfo.InvariantCulture)&#xD;&#xA;grandTotalRow(&quot;SALDO BANCO&quot;) = grandTotalSaldoBanco.ToString(&quot;F2&quot;, System.Globalization.CultureInfo.InvariantCulture)&#xD;&#xA;grandTotalRow(&quot;DIFERENCIA&quot;) = grandTotalDiferencia.ToString(&quot;F2&quot;, System.Globalization.CultureInfo.InvariantCulture)&#xD;&#xA;dtBoletinFinanciero.Rows.Add(grandTotalRow)" DisplayName="Invoke Code - Generar Subtotales" sap:VirtualizedContainerService.HintSize="546,197" sap2010:WorkflowViewState.IdRef="InvokeCode_1">
