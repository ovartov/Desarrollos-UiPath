      <ui:InvokeCode ContinueOnError="{x:Null}" Code="' ============================================================&#xD;&#xA;' OBJETIVO: Convertir un DataTable a formato JSON&#xD;&#xA;' INPUT:  dtMatrizRefinamiento (DataTable)&#xD;&#xA;' OUTPUT: strJsonMatrizRefinamiento (String)&#xD;&#xA;' ============================================================&#xD;&#xA;&#xD;&#xA;' StringBuilder para construir el JSON de forma eficiente&#xD;&#xA;Dim sb As New System.Text.StringBuilder&#xD;&#xA;&#xD;&#xA;' Lista para almacenar los nombres de las columnas (títulos)&#xD;&#xA;Dim columns As New List(Of String)&#xD;&#xA;&#xD;&#xA;' ── VALIDACIÓN: Verificar que la tabla no sea nula o esté vacía ──&#xD;&#xA;If dtMatrizRefinamiento Is Nothing Then&#xD;&#xA;    ' Si la tabla es Nothing, retorna un JSON vacío y termina&#xD;&#xA;    strJsonMatrizRefinamiento = &quot;[]&quot;&#xD;&#xA;    Exit Sub&#xD;&#xA;End If&#xD;&#xA;&#xD;&#xA;If dtMatrizRefinamiento.Columns.Count = 0 Then&#xD;&#xA;    ' Si la tabla no tiene columnas definidas, retorna JSON vacío&#xD;&#xA;    strJsonMatrizRefinamiento = &quot;[]&quot;&#xD;&#xA;    Exit Sub&#xD;&#xA;End If&#xD;&#xA;&#xD;&#xA;If dtMatrizRefinamiento.Rows.Count = 0 Then&#xD;&#xA;    ' Si la tabla tiene columnas pero ninguna fila de datos,&#xD;&#xA;    ' retorna JSON vacío&#xD;&#xA;    strJsonMatrizRefinamiento = &quot;[]&quot;&#xD;&#xA;    Exit Sub&#xD;&#xA;End If&#xD;&#xA;' ────────────────────────────────────────────────────────────&#xD;&#xA;&#xD;&#xA;' ── PASO 1: Extraer los títulos/columnas del DataTable ──────&#xD;&#xA;For Each col As DataColumn In dtMatrizRefinamiento.Columns&#xD;&#xA;    columns.Add(col.ColumnName) ' Agrega cada nombre de columna a la lista&#xD;&#xA;Next&#xD;&#xA;&#xD;&#xA;' Inicia el array JSON con corchete de apertura&#xD;&#xA;sb.AppendLine(&quot;[&quot;)&#xD;&#xA;&#xD;&#xA;' Lista que acumulará cada fila como objeto JSON {&quot;col&quot;: &quot;val&quot;, ...}&#xD;&#xA;Dim rowList As New List(Of String)&#xD;&#xA;&#xD;&#xA;' ── PASO 2: Iterar cada fila del DataTable ──────────────────&#xD;&#xA;For Each row As DataRow In dtMatrizRefinamiento.Rows&#xD;&#xA;    &#xD;&#xA;    ' Lista de pares &quot;clave&quot;: &quot;valor&quot; para la fila actual&#xD;&#xA;    Dim fieldList As New List(Of String)&#xD;&#xA;    &#xD;&#xA;    ' ── PASO 3: Iterar cada columna de la fila actual ───────&#xD;&#xA;    For Each col As String In columns&#xD;&#xA;        Dim value As String = &quot;&quot;&#xD;&#xA;        &#xD;&#xA;        ' Verifica que la celda no sea nula antes de leer su valor&#xD;&#xA;        If Not IsDBNull(row(col)) Then&#xD;&#xA;            ' Convierte a string y escapa caracteres especiales&#xD;&#xA;            ' para que el JSON sea válido:&#xD;&#xA;            '   \  →  \\   (barra invertida)&#xD;&#xA;            '   &quot;  →  \&quot;   (comilla doble)&#xD;&#xA;            value = row(col).ToString() _&#xD;&#xA;                        .Replace(&quot;\&quot;, &quot;\\&quot;) _&#xD;&#xA;                        .Replace(&quot;&quot;&quot;&quot;, &quot;\&quot;&quot;&quot;)&#xD;&#xA;        End If&#xD;&#xA;        &#xD;&#xA;        ' Construye el par &quot;NombreColumna&quot;: &quot;Valor&quot; y lo agrega&#xD;&#xA;        fieldList.Add(&quot;&quot;&quot;&quot; &amp; col &amp; &quot;&quot;&quot;: &quot;&quot;&quot; &amp; value &amp; &quot;&quot;&quot;&quot;)&#xD;&#xA;    Next&#xD;&#xA;    &#xD;&#xA;    ' Une todos los pares de la fila con coma y los envuelve en {}&#xD;&#xA;    rowList.Add(&quot;  {&quot; &amp; String.Join(&quot;, &quot;, fieldList) &amp; &quot;}&quot;)&#xD;&#xA;Next&#xD;&#xA;&#xD;&#xA;' ── PASO 4: Unir todas las filas y cerrar el JSON ───────────&#xD;&#xA;&#xD;&#xA;' Une cada objeto JSON de fila separado por coma y salto de línea&#xD;&#xA;sb.Append(String.Join(&quot;,&quot; &amp; Environment.NewLine, rowList))&#xD;&#xA;&#xD;&#xA;' Agrega salto de línea final y cierra el array JSON&#xD;&#xA;sb.AppendLine(&quot;&quot;)&#xD;&#xA;sb.AppendLine(&quot;]&quot;)&#xD;&#xA;&#xD;&#xA;' ── PASO 5: Asignar el resultado al argumento de salida ─────&#xD;&#xA;strJsonMatrizRefinamiento = sb.ToString()" DisplayName="Invoke Code - Matriz Refinamiento Json" sap:VirtualizedContainerService.HintSize="450,197" sap2010:WorkflowViewState.IdRef="InvokeCode_1">
