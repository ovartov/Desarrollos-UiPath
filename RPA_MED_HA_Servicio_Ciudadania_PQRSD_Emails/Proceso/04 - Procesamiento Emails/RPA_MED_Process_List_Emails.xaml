        <ui:InvokeCode ContinueOnError="{x:Null}" Code="' ============================================================&#xA;' OBJETIVO: Convertir un DataTable a formato JSON&#xA;' INPUT:  dtMatrizRefinamiento (DataTable)&#xA;' OUTPUT: strJsonMatrizRefinamiento (String)&#xA;' ============================================================&#xA;&#xA;' StringBuilder para construir el JSON de forma eficiente&#xA;Dim sb As New System.Text.StringBuilder&#xA;&#xA;' Lista para almacenar los nombres de las columnas (títulos)&#xA;Dim columns As New List(Of String)&#xA;&#xA;' ── VALIDACIÓN: Verificar que la tabla no sea nula o esté vacía ──&#xA;If dtMatrizRefinamiento Is Nothing Then&#xA;    ' Si la tabla es Nothing, retorna un JSON vacío y termina&#xA;    strJsonMatrizRefinamiento = &quot;[]&quot;&#xA;    Exit Sub&#xA;End If&#xA;&#xA;If dtMatrizRefinamiento.Columns.Count = 0 Then&#xA;    ' Si la tabla no tiene columnas definidas, retorna JSON vacío&#xA;    strJsonMatrizRefinamiento = &quot;[]&quot;&#xA;    Exit Sub&#xA;End If&#xA;&#xA;If dtMatrizRefinamiento.Rows.Count = 0 Then&#xA;    ' Si la tabla tiene columnas pero ninguna fila de datos,&#xA;    ' retorna JSON vacío&#xA;    strJsonMatrizRefinamiento = &quot;[]&quot;&#xA;    Exit Sub&#xA;End If&#xA;' ────────────────────────────────────────────────────────────&#xA;&#xA;' ── PASO 1: Extraer los títulos/columnas del DataTable ──────&#xA;For Each col As DataColumn In dtMatrizRefinamiento.Columns&#xA;    columns.Add(col.ColumnName) ' Agrega cada nombre de columna a la lista&#xA;Next&#xA;&#xA;' Inicia el array JSON con corchete de apertura&#xA;sb.AppendLine(&quot;[&quot;)&#xA;&#xA;' Lista que acumulará cada fila como objeto JSON {&quot;col&quot;: &quot;val&quot;, ...}&#xA;Dim rowList As New List(Of String)&#xA;&#xA;' ── PASO 2: Iterar cada fila del DataTable ──────────────────&#xA;For Each row As DataRow In dtMatrizRefinamiento.Rows&#xA;    &#xA;    ' Lista de pares &quot;clave&quot;: &quot;valor&quot; para la fila actual&#xA;    Dim fieldList As New List(Of String)&#xA;    &#xA;    ' ── PASO 3: Iterar cada columna de la fila actual ───────&#xA;    For Each col As String In columns&#xA;        Dim value As String = &quot;&quot;&#xA;        &#xA;        ' Verifica que la celda no sea nula antes de leer su valor&#xA;        If Not IsDBNull(row(col)) Then&#xA;            ' Convierte a string y escapa caracteres especiales&#xA;            ' para que el JSON sea válido:&#xA;            '   \  →  \\   (barra invertida)&#xA;            '   &quot;  →  \&quot;   (comilla doble)&#xA;            value = row(col).ToString() _&#xA;                        .Replace(&quot;\&quot;, &quot;\\&quot;) _&#xA;                        .Replace(&quot;&quot;&quot;&quot;, &quot;\&quot;&quot;&quot;)&#xA;        End If&#xA;        &#xA;        ' Construye el par &quot;NombreColumna&quot;: &quot;Valor&quot; y lo agrega&#xA;        fieldList.Add(&quot;&quot;&quot;&quot; &amp; col &amp; &quot;&quot;&quot;: &quot;&quot;&quot; &amp; value &amp; &quot;&quot;&quot;&quot;)&#xA;    Next&#xA;    &#xA;    ' Une todos los pares de la fila con coma y los envuelve en {}&#xA;    rowList.Add(&quot;  {&quot; &amp; String.Join(&quot;, &quot;, fieldList) &amp; &quot;}&quot;)&#xA;Next&#xA;&#xA;' ── PASO 4: Unir todas las filas y cerrar el JSON ───────────&#xA;&#xA;' Une cada objeto JSON de fila separado por coma y salto de línea&#xA;sb.Append(String.Join(&quot;,&quot; &amp; Environment.NewLine, rowList))&#xA;&#xA;' Agrega salto de línea final y cierra el array JSON&#xA;sb.AppendLine(&quot;&quot;)&#xA;sb.AppendLine(&quot;]&quot;)&#xA;&#xA;' ── PASO 5: Asignar el resultado al argumento de salida ─────&#xA;strJsonMatrizRefinamiento = sb.ToString()" DisplayName="Invoke Code - Matriz Refinamiento Json" sap:VirtualizedContainerService.HintSize="484,197" sap2010:WorkflowViewState.IdRef="InvokeCode_6">
