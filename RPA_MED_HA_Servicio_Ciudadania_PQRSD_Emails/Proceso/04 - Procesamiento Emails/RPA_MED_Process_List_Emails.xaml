        <ui:InvokeCode ContinueOnError="{x:Null}" Code="' ============================================================&#xA;' PASO 1: Crear tabla unificada con solo las 3 columnas comunes&#xA;' ============================================================&#xA;Dim dtUnificada As New System.Data.DataTable&#xA;dtUnificada.Columns.Add(&quot;AREA&quot;, GetType(String))&#xA;dtUnificada.Columns.Add(&quot;TEMA&quot;, GetType(String))&#xA;dtUnificada.Columns.Add(&quot;DESCRIPCION DEL TEMA&quot;, GetType(String))&#xA;&#xA;' Copiar filas de dtMatrizMovilidad&#xA;For Each row As DataRow In dtMatrizMovilidad.Rows&#xA;    dtUnificada.Rows.Add(&#xA;        If(IsDBNull(row(&quot;AREA&quot;)), &quot;&quot;, row(&quot;AREA&quot;).ToString().Trim()),&#xA;        If(IsDBNull(row(&quot;TEMA&quot;)), &quot;&quot;, row(&quot;TEMA&quot;).ToString().Trim()),&#xA;        If(IsDBNull(row(&quot;DESCRIPCION DEL TEMA&quot;)), &quot;&quot;, row(&quot;DESCRIPCION DEL TEMA&quot;).ToString().Trim())&#xA;    )&#xA;Next&#xA;&#xA;' Copiar filas de dtMatrizPqrsd&#xA;For Each row As DataRow In dtMatrizPqrsd.Rows&#xA;    dtUnificada.Rows.Add(&#xA;        If(IsDBNull(row(&quot;AREA&quot;)), &quot;&quot;, row(&quot;AREA&quot;).ToString().Trim()),&#xA;        If(IsDBNull(row(&quot;TEMA&quot;)), &quot;&quot;, row(&quot;TEMA&quot;).ToString().Trim()),&#xA;        If(IsDBNull(row(&quot;DESCRIPCION DEL TEMA&quot;)), &quot;&quot;, row(&quot;DESCRIPCION DEL TEMA&quot;).ToString().Trim())&#xA;    )&#xA;Next&#xA;&#xA;' ============================================================&#xA;' PASO 2: Agrupar por AREA -&gt; TEMA -&gt; Lista de Descripciones&#xA;' ============================================================&#xA;Dim grouped = dtUnificada.AsEnumerable() _&#xA;    .GroupBy(Function(r) r(&quot;AREA&quot;).ToString().Trim()) _&#xA;    .ToDictionary(&#xA;        Function(areaGroup) areaGroup.Key,&#xA;        Function(areaGroup)&#xA;            Return areaGroup _&#xA;                .GroupBy(Function(r) r(&quot;TEMA&